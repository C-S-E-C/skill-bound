{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Bound",
  "version": "0.1.0",
  "identifier": "com.csec.skillbound",
  "build": {
    "beforeDevCommand": "python -m http.server 1420 --directory ..",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": ".."
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Skill Bound",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
